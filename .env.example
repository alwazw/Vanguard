# THE VANGUARD PROTOCOL - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in the values.

# --- GLOBAL CONFIGURATION ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# --- PERFORMANCE ---
NEXT_TELEMETRY_DISABLED=1

# --- CORE INTEGRATION (PLACEHOLDERS) ---
# NEXT_PUBLIC_ANALYTICS_ID=UA-XXXXXX-X
# NEXT_PUBLIC_API_ENDPOINT=https://api.vanguardprotocol.io/v1

# --- SECURITY ---
# AUTH_SECRET=your-32-character-secret-here
# STRATEGIC_ACCESS_KEY=your-vanguard-key

# --- 3D RENDERER ---
# THREE_D_ACCELERATION=true
# LOW_POWER_MODE=false
